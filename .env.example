# App
APP_ENV=development
DEBUG=true

# Database (async SQLAlchemy; default: local Postgres user `postgres`, DB `bearinmind`)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bearinmind

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB (HTTP API; docker maps host 3333 -> container 8000)
CHROMA_HOST=localhost
CHROMA_PORT=3333

# Optional: uncomment to run LLM smoke (scripts/llm_smoke.py or tests)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
