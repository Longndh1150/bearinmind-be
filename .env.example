# App
APP_ENV=development
DEBUG=true

# Database (async SQLAlchemy; default: local Postgres user `postgres`, DB `bearinmind`)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bearinmind

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB (HTTP API; docker maps host 3333 -> container 8000)
CHROMA_HOST=localhost
CHROMA_PORT=3333

# Optional: generic LLM config (OpenAI-compatible)
# - OpenAI
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
#
# - OpenRouter (OpenAI SDK compatible)
# LLM_API_KEY=<OPENROUTER_API_KEY>
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini
