# App
APP_ENV=development
DEBUG=true

# Database (async SQLAlchemy; default: local Postgres user `postgres`, DB `bearinmind`)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bearinmind

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB (HTTP API; docker maps host 3333 -> container 8000)
CHROMA_HOST=localhost
CHROMA_PORT=3333

# HubSpot
HUBSPOT_API_KEY=<HUBSPOT_API_KEY>
HUBSPOT_BASE_URL=https://api.hubapi.com

# Auth (JWT)
# IMPORTANT: change this in real environments
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ISSUER=bearinmind
JWT_AUDIENCE=bearinmind-fe
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Optional: generic LLM config (OpenAI-compatible)
# - OpenAI
# LLM_API_KEY=
# LLM_MODEL_PRIMARY=gpt-4o
# LLM_MODEL_SECONDARY=gpt-4o-mini
#
# - OpenRouter/Gemini/Other (OpenAI SDK compatible)
LLM_API_KEY=<OPENROUTER_API_KEY>
LLM_BASE_URL=https://openrouter.ai/api/v1
# Primary: heavy tasks — intent classification, entity extraction, ranking, answer gen
LLM_MODEL_PRIMARY=google/gemini-2.5-pro
# Secondary: light tasks — conversation title generation, short summaries
LLM_MODEL_SECONDARY=google/gemini-2.5-flash-preview
